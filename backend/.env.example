# Copy this file to .env and fill in real values before starting the server

# MongoDB connection string (Atlas or self-hosted)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_long_random_secret_string

# Groq AI API key (used for chatbot and SEO generation)
GROQ_API_KEY=gsk_replace_with_your_groq_api_key

# Public site URL (used in SEO meta tags and canonical URLs)
SITE_URL=https://yourdomain.com

# Port (optional — defaults to 5055)
PORT=5055

# Set to "production" for production deployments
NODE_ENV=production
